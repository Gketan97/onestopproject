#!/bin/bash

echo "ЁЯЪв Ship Script тАФ AI Case Platform"

BRANCH=$(git rev-parse --abbrev-ref HEAD)
TIMESTAMP=$(date "+%Y-%m-%d %H:%M")

echo "Branch: $BRANCH"

COMMIT_MSG="ship: AI platform update ($TIMESTAMP)"

git add -A
git commit -m "$COMMIT_MSG"
git push origin $BRANCH || {
  echo "тЭМ Push failed."
  exit 1
}

echo ""
echo "ЁЯЪА Ship complete!"
echo "Branch: $BRANCH"
echo "Netlify should deploy shortly."

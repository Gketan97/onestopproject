#!/bin/bash

echo "🚀 OneStop AI Platform — Ship Command"

# detect current branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# timestamp for commit message
TIMESTAMP=$(date "+%Y-%m-%d %H:%M")

echo "📍 Branch: $BRANCH"
echo ""

echo "📦 Staging all changes..."
git add -A

# if nothing changed
if git diff-index --quiet HEAD --; then
  echo "✅ No changes detected. Nothing to ship."
  exit 0
fi

echo "💾 Creating commit..."
git commit -m "ship: platform update ($TIMESTAMP)"

echo "⬆️ Pushing to GitHub..."
git push origin $BRANCH

echo ""
echo "🚢 Ship successful!"
echo "🌐 Netlify will now automatically deploy your site."
echo ""
echo "Done."

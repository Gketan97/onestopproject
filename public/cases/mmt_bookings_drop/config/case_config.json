  "groundTruth": {
    "rootCause": "Four compounding causes: (1) Choice overload from homestay expansion causing browsing fatigue — 35% of drop. (2) Review consumption leading to decision paralysis — 28% of drop. (3) HVT behavioral shift to bundled packages — 22% of drop. (4) Visa uncertainty delaying international bookings — 15% of drop.",
    "affectedMetrics": [
      "bookings_per_dau",
      "serp_to_click_rate",
      "review_dwell_time",
      "payment_abandonment",
      "hvt_cvr",
      "international_search_cvr"
    ],
    "anomalyStartWeek": 5,
    "anomalyEndWeek": 12,
    "expectedFindings": [
      "Bookings/DAU 8.2% to 7.1% over 60 days",
      "DAU +15% driven by low-LTV new users",
      "HVT CVR 14.2% to 11.1%",
      "Review dwell time +140% for HVT",
      "Homestay listings in top-5 results increased from 18% to 41% for vacation searches",
      "International search CVR dropped from 9.1% to 5.2%",
      "Visa-related session exits increased 3.1x",
      "HVT package page visits increased 2.8x"
    ]
  },

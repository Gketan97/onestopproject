#!/bin/bash

BRANCH="v3"
PREVIEW_PORT=4173

echo ""
echo "🚀 Smart Dev Script — V3"
echo "────────────────────────────"

CURRENT_BRANCH=$(git branch --show-current)
if [ "$CURRENT_BRANCH" != "$BRANCH" ]; then
  echo "⚠️ Switching to '$BRANCH'..."
  git checkout $BRANCH || exit 1
fi
echo "✅ Branch: $BRANCH"

echo ""
echo "📂 Changed files:"
git status --short

if [ -z "$(git status --porcelain)" ]; then
  echo "⚠️ No changes detected."
  exit 0
fi

echo ""
echo "🧹 Cleaning cache..."
rm -rf dist node_modules/.cache

export NODE_OPTIONS="--max-old-space-size=4096"

if [ ! -d "node_modules" ]; then
  echo "📦 Installing dependencies..."
  npm install || exit 1
fi

if npm run | grep -q " lint"; then
  echo ""
  echo "🔍 Linting..."
  npm run lint || { echo "❌ Lint failed"; exit 1; }
fi

echo ""
echo "🧠 Type checking..."
npx tsc --noEmit || { echo "❌ Type errors"; exit 1; }

echo ""
echo "🔨 Building..."
npm run build || { echo "❌ Build failed"; exit 1; }
echo "✅ Build success"

echo ""
echo "🌐 Starting preview on :$PREVIEW_PORT..."
npm run preview &
PREVIEW_PID=$!
sleep 3
open "http://localhost:$PREVIEW_PORT" 2>/dev/null || echo "Open http://localhost:$PREVIEW_PORT"

echo ""
read -p "Deploy changes? (y/n): " CONFIRM
kill $PREVIEW_PID 2>/dev/null

if [[ "$CONFIRM" != "y" ]]; then
  echo "🛑 Aborted"
  exit 0
fi

read -p "Commit message: " MSG
MSG=${MSG:-"v3 update"}

git add -A
git commit -m "$MSG" || exit 1
git push origin $BRANCH

echo ""
echo "✅ Done. Pushed to $BRANCH"

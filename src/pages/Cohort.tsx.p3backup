const FRAMEWORK_STEPS = [
  { n: '01', title: 'Understand the business', desc: 'What does PlanMyTrip actually care about? Revenue model, margin by segment, strategic priorities. You cannot diagnose a business problem without understanding the business.' },
  { n: '02', title: 'Define the real problem', desc: 'Convert "conversion is down" into a precise metric, time window, baseline, and scope. Most people skip this and solve the wrong problem brilliantly.' },
  { n: '03', title: 'Build your metric tree', desc: 'Decompose the primary metric into its drivers. Search-to-booking = listing click rate × checkout rate × payment success. Where does the tree break?' },
  { n: '04', title: 'Generate hypotheses', desc: 'List all plausible causes across traffic quality, product, pricing, payment, experiments, and data quality. Do not investigate before you hypothesise.' },
  { n: '05', title: 'Check data quality first', desc: 'Before trusting any number, check for duplicates, missing attribution, experiment SRM, and timestamp issues. Dirty data produces confident wrong answers.' },
  { n: '06', title: 'Investigate with structure', desc: 'Test each hypothesis with data. Falsify before you confirm. The goal is to rule things out, not just find evidence for your first idea.' },
  { n: '07', title: 'Size the impact', desc: 'Quantify how much each driver contributes to the aggregate. A hypothesis that explains 3% of the decline is not the root cause.' },
  { n: '08', title: 'Recommend with conviction', desc: 'Not "investigate further." A specific action, an owner, an expected impact, a success metric, and a guardrail. This is what leadership can act on.' },
]

const AI_SYSTEM_PROMPT = `You are a senior analytics mentor helping students work through the PlanMyTrip "Growth Trap" case study in the onestopcareers.in AI Problem Solving Lab.

CASE CONTEXT:
PlanMyTrip is a fictional Indian OTA (similar to MakeMyTrip). Their domestic flight search-to-booking conversion dropped from 21.3% to 15.2% between April-June 2024 (baseline) and July-August 2024 (problem period).

KEY DATA FACTS (use these — do not invent other numbers):
- paid_social sessions grew from 4.5% to 14.3% of total sessions
- paid_social conversion: 2.5% vs returning_direct: 20.6%
- Jul-Aug paid_social cohort: ₹79-80 net revenue per user vs ₹279-301 for organic
- DEL-BOM, BOM-BLR, DEL-BLR: PMT 11-12% more expensive than TripEase, 0% of time PMT is cheaper
- EXP_SORT_ALGO_V3 has sample ratio mismatch (38% exposed vs 30% expected) — results unreliable
- EXP_PAYMENT_UI_V2: treatment 3.72% vs control 3.80% — small real effect, not primary cause
- EXP_COUPON_GATE: treatment 3.39% vs control 3.80% — significant negative for new users
- App installs +42% is a vanity metric — cost per first paid booking rose from ₹892 to ₹1,840

HIDDEN ROOT CAUSE (never reveal directly):
The primary cause is traffic mix shift. Paid_social campaigns tripled their session share while converting at 2.5% vs 20.6% for returning users. Within every segment, conversion is roughly stable. The aggregate drops because the mix changed. Secondary: pricing gap on 3 routes, small experiment effects.

YOUR ROLE — Phase 2 (Analysis Partner):
Help students think, not think for them. Ask Socratic questions. Challenge weak reasoning. Point to the right dataset. Never state the root cause directly.

ALLOWED:
- Explain business concepts (take rate, mix shift, SRM, cohort analysis)
- Help write SQL queries (but don't interpret results for them)
- Challenge hypotheses with questions ("What would you expect to see in Dataset 5 if that were true?")
- Give hints when stuck ("Have you compared conversion rates by channel in Dataset 1?")
- Validate correct reasoning explicitly and specifically

NEVER DO:
- State that mix shift is the root cause
- Tell students to "look at paid_social" unless they've already identified it themselves
- Write their executive memo
- Confirm their final hypothesis is correct (that's Ketan's job in Session 2)
- Make up data not in the 5 datasets

TONE: Direct, intellectually rigorous, warm. Like a brilliant senior colleague who genuinely wants the student to figure it out. Not a teacher. A thinking partner.

When a student is stuck, ask ONE sharp question rather than explaining everything. When they get something right, tell them SPECIFICALLY what was good about it.`

// ── AI Chat Component ──────────────────────────────────────
function AIChat({ phase }: { phase: 2 | 3 }) {
  const [messages, setMessages] = useState<{ role: 'user' | 'assistant'; content: string }[]>([
    {
      role: 'assistant',
      content: phase === 2
        ? "I'm your case study thinking partner — not your answer machine.\n\nBefore we start: tell me where you are. Have you looked at the 5 datasets yet? If yes — what's your current hypothesis? If no — start with Dataset 1 and tell me what you notice about the conversion rates by channel."
        : "Phase 3 — this is about turning your analysis into something Ketan can evaluate on Saturday.\n\nWalk me through your current structure. What is your root cause, what evidence supports it, and what is your recommendation? I'll tell you where the logic is weak and where it's strong.",
    },
  ])
  const [input, setInput] = useState('')
  const [loading, setLoading] = useState(false)
  const bottomRef = useRef<HTMLDivElement>(null)

  useEffect(() => { bottomRef.current?.scrollIntoView({ behavior: 'smooth' }) }, [messages])

  async function send() {
    if (!input.trim() || loading) return
    const userMsg = input.trim()
    setInput('')
    setMessages(prev => [...prev, { role: 'user', content: userMsg }])
    setLoading(true)

    const phaseCtx = phase === 2
      ? 'Student is in Phase 2 — working through the data. Guide their analysis. Do not reveal the root cause.'
      : 'Student is in Phase 3 — documenting findings. Help structure their executive communication. Challenge vague recommendations.'

    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': import.meta.env.VITE_ANTHROPIC_API_KEY ?? '',
          'anthropic-version': '2023-06-01',
          'anthropic-dangerous-allow-browser': 'true',
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-5',
          max_tokens: 500,
          system: AI_SYSTEM_PROMPT + '\n\nCURRENT PHASE: ' + phaseCtx,
          messages: [
            ...messages.map(m => ({ role: m.role, content: m.content })),
            { role: 'user', content: userMsg },
          ],
        }),
      })
      const data = await res.json()
      const text = data.content?.[0]?.text ?? 'Something went wrong. Try again.'
      setMessages(prev => [...prev, { role: 'assistant', content: text }])
    } catch {
      setMessages(prev => [...prev, { role: 'assistant', content: 'Network error — check your connection and try again.' }])
    } finally {
      setLoading(false)
    }
  }

  return (
    <div style={{ background: 'var(--bg-base)', border: '1px solid rgba(168,85,247,0.25)', borderRadius: 16, overflow: 'hidden', display: 'flex', flexDirection: 'column', height: 520 }}>
      <div style={{ padding: '14px 20px', borderBottom: '1px solid var(--border-subtle)', background: 'rgba(168,85,247,0.05)', display: 'flex', alignItems: 'center', gap: 10 }}>
        <div style={{ width: 8, height: 8, borderRadius: '50%', background: '#4ade80', boxShadow: '0 0 6px #4ade80', animation: 'cs-pulse 2s infinite' }} />
        <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 12, letterSpacing: '0.1em', color: 'var(--text-primary)' }}>
          {phase === 2 ? 'AI ANALYSIS PARTNER' : 'AI REPORT COACH'}
        </span>
        <span style={{ marginLeft: 'auto', fontFamily: 'DM Mono, monospace', fontSize: 10, color: 'var(--text-tertiary)', letterSpacing: '0.06em' }}>WILL GUIDE · WON'T ANSWER</span>
      </div>
      <div style={{ flex: 1, overflowY: 'auto', padding: 20, display: 'flex', flexDirection: 'column', gap: 14 }}>
        {messages.map((m, i) => (
          <div key={i} style={{ display: 'flex', justifyContent: m.role === 'user' ? 'flex-end' : 'flex-start' }}>
            <div style={{
              maxWidth: '82%',
              background: m.role === 'user' ? 'var(--accent)' : 'var(--bg-elevated)',
              border: m.role === 'assistant' ? '1px solid var(--border-subtle)' : 'none',
              borderRadius: m.role === 'user' ? '16px 16px 4px 16px' : '4px 16px 16px 16px',
              padding: '12px 16px',
              fontFamily: 'DM Sans, sans-serif', fontSize: 14, lineHeight: 1.7,
              color: m.role === 'user' ? '#fff' : 'var(--text-secondary)',
              whiteSpace: 'pre-wrap',
            }}>{m.content}</div>
          </div>
        ))}
        {loading && (
          <div style={{ display: 'flex', gap: 5, padding: '8px 4px' }}>
            {[0,1,2].map(i => <div key={i} style={{ width: 6, height: 6, borderRadius: '50%', background: 'var(--accent)', animation: `cs-dot 1.2s ease-in-out ${i*0.2}s infinite` }} />)}
          </div>
        )}
        <div ref={bottomRef} />
      </div>
      <div style={{ padding: '12px 16px', borderTop: '1px solid var(--border-subtle)', display: 'flex', gap: 10 }}>
        <textarea
          value={input}
          onChange={e => setInput(e.target.value)}
          onKeyDown={e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send() } }}
          placeholder={phase === 2 ? 'Share your hypothesis or ask about a dataset...' : 'Share your draft recommendation or structure...'}
          disabled={loading}
          style={{ flex: 1, background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 10, padding: '10px 14px', resize: 'none', height: 44, fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-primary)', outline: 'none', lineHeight: 1.5 }}
        />
        <button onClick={send} disabled={loading || !input.trim()} style={{ width: 44, height: 44, background: 'var(--accent)', border: 'none', borderRadius: 10, cursor: 'pointer', color: '#fff', fontSize: 18, opacity: loading || !input.trim() ? 0.4 : 1, flexShrink: 0 }}>↑</button>
      </div>
    </div>
  )
}

// ── Dataset Table (with 3-tier hint escalation + open tracking) ──────
function DatasetTable({ ds, onFirstOpen }: { ds: typeof DATASETS[0]; onFirstOpen: (id: string) => void }) {
  const [open, setOpen] = useState(false)
  const [hintLevel, setHintLevel] = useState(0) // 0=hidden, 1,2,3=revealed
  const openedRef = useRef(false)

  function handleToggle() {
    const next = !open
    setOpen(next)
    if (next && !openedRef.current) {
      openedRef.current = true
      onFirstOpen(ds.id)
    }
  }

  return (
    <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, overflow: 'hidden', marginBottom: 10 }}>
      <div onClick={handleToggle} style={{ padding: '16px 20px', cursor: 'pointer', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
        <div>
          <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, fontWeight: 600, color: 'var(--text-primary)', marginBottom: 2 }}>{ds.title}</div>
          <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-tertiary)' }}>{ds.description}</div>
        </div>
        <span style={{ color: 'var(--accent)', fontSize: 20, flexShrink: 0 }}>{open ? '−' : '+'}</span>
      </div>
      {open && (
        <div style={{ borderTop: '1px solid var(--border-subtle)' }}>
          <div style={{ overflowX: 'auto' }}>
            <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: 13 }}>
              <thead>
                <tr style={{ background: 'rgba(168,85,247,0.06)' }}>
                  {ds.headers.map((h, i) => (
                    <th key={i} style={{ padding: '10px 16px', textAlign: 'left', fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.08em', color: 'var(--accent)', fontWeight: 500, whiteSpace: 'nowrap' }}>{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {ds.rows.map((row, i) => (
                  <tr key={i} style={{ borderTop: '1px solid var(--border-subtle)', background: i%2===0 ? 'transparent' : 'rgba(255,255,255,0.01)' }}>
                    {row.map((cell, j) => {
                      const isRed = (cell.includes('%') && cell.startsWith('-') && j > 0) || (cell === '0%' && j === 4)
                      const isGreen = cell.includes('%') && cell.startsWith('+') && j > 0
                      return (
                        <td key={j} style={{ padding: '10px 16px', fontFamily: j===0 ? 'DM Sans, sans-serif' : 'DM Mono, monospace', fontSize: j===0 ? 13 : 12, color: isRed ? '#f87171' : isGreen ? '#4ade80' : 'var(--text-secondary)', fontWeight: j===0 ? 500 : 400, whiteSpace: 'nowrap' }}>{cell}</td>
                      )
                    })}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {/* Footer: note + 3-tier hint system */}
          <div style={{ padding: '10px 20px', borderTop: '1px solid var(--border-subtle)', background: 'rgba(0,0,0,0.1)', display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', gap: 12, flexWrap: 'wrap' }}>
            <span style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-tertiary)', lineHeight: 1.6 }}>{ds.note}</span>
            <div style={{ display: 'flex', gap: 6, flexShrink: 0, alignItems: 'center' }}>
              {hintLevel > 0 && (
                <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, color: 'var(--text-tertiary)', letterSpacing: '0.06em' }}>
                  HINT {hintLevel}/{ds.hints.length}
                </span>
              )}
              <button
                onClick={() => setHintLevel(l => Math.min(l + 1, ds.hints.length))}
                disabled={hintLevel >= ds.hints.length}
                style={{ background: hintLevel >= ds.hints.length ? 'rgba(255,255,255,0.04)' : 'rgba(168,85,247,0.1)', border: '1px solid rgba(168,85,247,0.2)', borderRadius: 8, padding: '5px 12px', fontFamily: 'DM Mono, monospace', fontSize: 10, color: hintLevel >= ds.hints.length ? 'var(--text-tertiary)' : 'var(--accent)', cursor: hintLevel >= ds.hints.length ? 'default' : 'pointer', whiteSpace: 'nowrap', letterSpacing: '0.06em' }}
              >
                {hintLevel === 0 ? '💡 HINT' : hintLevel >= ds.hints.length ? '✓ ALL HINTS SHOWN' : '💡 NEXT HINT'}
              </button>
            </div>
          </div>
          {/* Hint display — shows all revealed hints stacked */}
          {hintLevel > 0 && (
            <div style={{ borderTop: '1px solid var(--border-subtle)', background: 'rgba(168,85,247,0.04)' }}>
              {ds.hints.slice(0, hintLevel).map((hint, i) => (
                <div key={i} style={{ padding: '10px 20px', borderBottom: i < hintLevel - 1 ? '1px solid var(--border-subtle)' : 'none', display: 'flex', gap: 10, alignItems: 'flex-start' }}>
                  <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, color: 'var(--accent)', flexShrink: 0, paddingTop: 2 }}>H{i+1}</span>
                  <span style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.7 }}>{hint}</span>
                </div>
              ))}
              {hintLevel >= ds.hints.length && (
                <div style={{ padding: '10px 20px', fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-tertiary)', lineHeight: 1.5, borderTop: '1px solid var(--border-subtle)' }}>
                  All hints shown. Still stuck? Ask the AI Analysis Partner — share your current hypothesis and what's blocking you.
                </div>
              )}
            </div>
          )}
        </div>
      )}
    </div>
  )
}

// ── Reflection Checkpoint Modal ───────────────────────────────────────
function ReflectionCheckpoint({ onComplete }: { onComplete: (answer: string) => void }) {
  const [answer, setAnswer] = useState('')
  const [submitted, setSubmitted] = useState(false)

  function handleSubmit() {
    if (answer.trim().length < 20) return
    sessionStorage.setItem('phase2_reflection', answer.trim())
    sessionStorage.setItem('phase2_reflection_ts', Date.now().toString())
    setSubmitted(true)
    setTimeout(() => onComplete(answer.trim()), 800)
  }

  return (
    <div style={{ position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.7)', backdropFilter: 'blur(4px)', zIndex: 200, display: 'flex', alignItems: 'center', justifyContent: 'center', padding: 20 }}>
      <div style={{ background: 'var(--bg-elevated)', border: '1px solid rgba(168,85,247,0.25)', borderRadius: 20, padding: '36px 40px', maxWidth: 520, width: '100%', boxShadow: '0 24px 80px rgba(0,0,0,0.6)' }}>
        {!submitted ? (
          <>
            <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.16em', color: 'var(--accent)', marginBottom: 12 }}>⏸ REFLECTION CHECKPOINT</div>
            <h3 style={{ fontFamily: 'Instrument Serif, serif', fontSize: 24, fontWeight: 400, color: 'var(--text-primary)', lineHeight: 1.3, marginBottom: 12 }}>
              Pause before you continue.
            </h3>
            <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.75, marginBottom: 6 }}>
              You've now looked at the funnel, cohort quality, and competitor pricing.
            </p>
            <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.75, marginBottom: 24 }}>
              <strong style={{ color: 'var(--text-primary)' }}>What is your current hypothesis for the conversion decline?</strong> State it in one sentence. It doesn't have to be right — it has to be specific.
            </p>
            <textarea
              autoFocus
              value={answer}
              onChange={e => setAnswer(e.target.value)}
              placeholder="e.g. The conversion decline is primarily caused by..."
              style={{ width: '100%', boxSizing: 'border-box', background: 'var(--bg-base)', border: `1px solid ${answer.trim().length > 0 && answer.trim().length < 20 ? 'rgba(251,191,36,0.4)' : 'var(--border-subtle)'}`, borderRadius: 10, padding: '12px 16px', fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-primary)', resize: 'none', height: 100, lineHeight: 1.65, outline: 'none', marginBottom: 6 }}
            />
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
              <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, color: answer.trim().length < 20 ? 'rgba(251,191,36,0.7)' : '#4ade80', letterSpacing: '0.06em' }}>
                {answer.trim().length < 20 ? `${20 - answer.trim().length} more characters needed` : '✓ Ready to save'}
              </span>
            </div>
            <button
              onClick={handleSubmit}
              disabled={answer.trim().length < 20}
              style={{ width: '100%', background: answer.trim().length >= 20 ? 'var(--accent)' : 'var(--bg-base)', border: '1px solid var(--border-subtle)', borderRadius: 100, padding: '13px', color: answer.trim().length >= 20 ? '#fff' : 'var(--text-tertiary)', fontFamily: 'DM Sans, sans-serif', fontSize: 15, fontWeight: 600, cursor: answer.trim().length >= 20 ? 'pointer' : 'not-allowed', transition: 'all 200ms' }}
            >
              Save & Continue Investigation →
            </button>
            <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-tertiary)', textAlign: 'center', marginTop: 12, marginBottom: 0, lineHeight: 1.5 }}>
              Your hypothesis will be shown to you in Phase 3 to help structure your report.
            </p>
          </>
        ) : (
          <div style={{ textAlign: 'center', padding: '20px 0' }}>
            <div style={{ fontSize: 32, marginBottom: 12 }}>✓</div>
            <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 15, color: '#4ade80', marginBottom: 0 }}>Hypothesis saved. Continuing...</p>
          </div>
        )}
      </div>
    </div>
  )
}

// ── Phase Lock ─────────────────────────────────────────────
function PhaseLock({ onUnlock }: { onUnlock: () => void }) {
  const [kw, setKw] = useState('')
  const [err, setErr] = useState(false)
  const [shake, setShake] = useState(false)

  function tryUnlock() {
    if (kw.trim().toUpperCase() === PHASE2_KEYWORD) {
      sessionStorage.setItem('cohort_unlocked', PHASE2_KEYWORD)
      onUnlock()
    } else {
      setErr(true)
      setShake(true)
      setTimeout(() => { setErr(false); setShake(false) }, 2000)
    }
  }

  return (
    <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 20, padding: '56px 40px', textAlign: 'center', maxWidth: 440, margin: '0 auto' }}>
      <div style={{ fontSize: 40, marginBottom: 20 }}>🔒</div>
      <h3 style={{ fontFamily: 'Instrument Serif, serif', fontSize: 26, color: 'var(--text-primary)', fontWeight: 400, marginBottom: 12, lineHeight: 1.3 }}>Phase 2 unlocks after Saturday</h3>
      <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.75, marginBottom: 32 }}>
        Ketan will share the unlock keyword at the end of Session 1. Enter it here to access the full dataset explorer and AI Analysis Partner.
      </p>
      <input
        type="text"
        placeholder="Enter keyword from Ketan..."
        value={kw}
        onChange={e => setKw(e.target.value)}
        onKeyDown={e => e.key === 'Enter' && tryUnlock()}
        autoFocus
        style={{
          width: '100%', boxSizing: 'border-box',
          background: 'var(--bg-base)', border: `1px solid ${err ? '#f87171' : 'var(--border-subtle)'}`,
          borderRadius: 10, padding: '13px 16px', marginBottom: 12,
          fontFamily: 'DM Mono, monospace', fontSize: 15, color: 'var(--text-primary)',
          outline: 'none', textAlign: 'center', letterSpacing: '0.12em',
          animation: shake ? 'cs-shake 0.3s ease' : 'none',
          transition: 'border-color 200ms',
        }}
      />
      {err && <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: '#f87171', marginBottom: 12 }}>Incorrect keyword. Try again or message Ketan in the WhatsApp group.</p>}
      <button onClick={tryUnlock} style={{ width: '100%', background: 'var(--accent)', border: 'none', borderRadius: 100, padding: '14px', color: '#fff', fontFamily: 'DM Sans, sans-serif', fontSize: 15, fontWeight: 600, cursor: 'pointer' }}>
        Unlock Phase 2 →
      </button>
    </div>
  )
}

// ── Section components ─────────────────────────────────────
const Label = ({ text }: { text: string }) => (
  <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 11, letterSpacing: '0.16em', color: 'var(--accent)', marginBottom: 14 }}>{text}</p>
)
const H2 = ({ children }: { children: React.ReactNode }) => (
  <h2 style={{ fontFamily: 'Instrument Serif, serif', fontSize: 'clamp(24px, 3vw, 36px)', fontWeight: 400, color: 'var(--text-primary)', lineHeight: 1.2, marginBottom: 14 }}>{children}</h2>
)
const Body = ({ children }: { children: React.ReactNode }) => (
  <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 15, color: 'var(--text-secondary)', lineHeight: 1.85, marginBottom: 16 }}>{children}</p>
)
const Callout = ({ children, accent = false }: { children: React.ReactNode; accent?: boolean }) => (
  <div style={{ background: accent ? 'rgba(168,85,247,0.06)' : 'var(--bg-elevated)', border: `1px solid ${accent ? 'rgba(168,85,247,0.2)' : 'var(--border-subtle)'}`, borderLeft: `3px solid ${accent ? 'var(--accent)' : 'var(--border-default)'}`, borderRadius: '0 12px 12px 0', padding: '16px 20px', marginBottom: 20, fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.75 }}>
    {children}
  </div>
)

// ── Main Page ──────────────────────────────────────────────
export default function Cohort() {
  const navigate = useNavigate()
  const [preReadDone, setPreReadDone] = useState(false)
  const [phase2Unlocked, setPhase2Unlocked] = useState(false)
  const [activeStakeholder, setActiveStakeholder] = useState<number | null>(null)
  const [activeFwStep, setActiveFwStep] = useState<number | null>(null)
  const [activeDashMetric, setActiveDashMetric] = useState<number | null>(null)
  const [datasetsOpened, setDatasetsOpened] = useState<Set<string>>(new Set())
  const [showReflection, setShowReflection] = useState(false)
  const [reflectionDone, setReflectionDone] = useState(false)
  const [reflectionAnswer, setReflectionAnswer] = useState('')
  const [phase2Complete, setPhase2Complete] = useState(false)

  useEffect(() => {
    window.scrollTo(0, 0)
    if (sessionStorage.getItem('preread_done') === '1') setPreReadDone(true)
    if (sessionStorage.getItem('cohort_unlocked') === PHASE2_KEYWORD) setPhase2Unlocked(true)
    // Restore Phase 2 progress
    const savedDatasets = sessionStorage.getItem('phase2_datasets_opened')
    if (savedDatasets) {
      try { setDatasetsOpened(new Set(JSON.parse(savedDatasets))) } catch {}
    }
    const savedReflection = sessionStorage.getItem('phase2_reflection')
    if (savedReflection) {
      setReflectionDone(true)
      setReflectionAnswer(savedReflection)
    }
    if (sessionStorage.getItem('phase2_complete') === '1') setPhase2Complete(true)
  }, [])

  const sec = (bg = 'var(--bg-base)') => ({ background: bg, borderTop: '1px solid var(--border-subtle)', padding: '72px 32px' } as React.CSSProperties)
  const inner = { maxWidth: 900, margin: '0 auto' } as React.CSSProperties

  if (!preReadDone) {
    return <PreRead onComplete={() => { sessionStorage.setItem('preread_done', '1'); setPreReadDone(true) }} />
  }

  return (
    <>
      <style>{`
        .cs-page { min-height: 100vh; background: var(--bg-base); }
        .cs-topbar { height: 60px; display: flex; align-items: center; padding: 0 32px; border-bottom: 1px solid var(--border-subtle); background: rgba(8,8,12,0.95); backdrop-filter: blur(14px); position: sticky; top: 0; z-index: 100; justify-content: space-between; }
        .cs-logo { font-family: 'DM Mono', monospace; font-size: 14px; letter-spacing: 0.1em; color: #fff; font-weight: 600; cursor: pointer; }
        .cs-logo span { background: linear-gradient(135deg,#FF6B9D,#A855F7); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }

        /* Journey map */
        .cs-journey { display: flex; align-items: flex-start; gap: 0; margin-bottom: 48px; overflow-x: auto; }
        .cs-journey-step { display: flex; flex-direction: column; align-items: center; min-width: 140px; }
        .cs-journey-dot { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 600; margin-bottom: 10px; flex-shrink: 0; }
        .cs-journey-dot.active { background: var(--accent); color: white; }
        .cs-journey-dot.locked { background: var(--bg-elevated); border: 1px solid var(--border-subtle); color: var(--text-tertiary); }
        .cs-journey-dot.open { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: #4ade80; }
        .cs-journey-label { font-family: 'DM Sans', sans-serif; font-size: 12px; color: var(--text-secondary); text-align: center; line-height: 1.4; }
        .cs-journey-label.locked { color: var(--text-tertiary); }
        .cs-journey-line { flex: 1; height: 1px; background: var(--border-subtle); margin-top: 18px; min-width: 32px; }

        /* Phase header */
        .cs-phase-hdr { display: flex; align-items: center; gap: 20px; margin-bottom: 28px; }
        .cs-phase-num { font-family: 'Instrument Serif', serif; font-size: 56px; color: rgba(168,85,247,0.15); font-weight: 400; line-height: 1; flex-shrink: 0; }

        /* Dashboard */
        .cs-dash-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-bottom: 28px; }
        .cs-dash-card { background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 16px 18px; cursor: pointer; transition: border-color 200ms; }
        .cs-dash-card:hover, .cs-dash-card.active { border-color: rgba(168,85,247,0.35); background: rgba(168,85,247,0.04); }
        .cs-dash-card.misleading { border-color: rgba(251,191,36,0.2); }
        .cs-dash-metric-name { font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
        .cs-dash-row { display: flex; align-items: baseline; gap: 12px; margin-bottom: 6px; flex-wrap: wrap; }
        .cs-dash-current { font-family: 'Instrument Serif', serif; font-size: 24px; color: var(--text-primary); }
        .cs-dash-baseline { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text-tertiary); }
        .cs-dash-change { font-family: 'DM Mono', monospace; font-size: 11px; }
        .cs-dash-note { font-family: 'DM Sans', sans-serif; font-size: 12px; color: var(--text-tertiary); line-height: 1.55; margin-top: 6px; }
        .cs-mislead-badge { display: inline-block; font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.08em; color: #fbbf24; background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.2); border-radius: 4px; padding: 2px 8px; margin-bottom: 6px; }

        /* Stakeholders */
        .cs-stakeholder-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 28px; }
        .cs-stk-card { background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 16px; cursor: pointer; transition: all 200ms; }
        .cs-stk-card:hover, .cs-stk-card.active { border-color: rgba(168,85,247,0.3); }
        .cs-stk-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; }
        .cs-stk-name { font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 2px; }
        .cs-stk-title { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.06em; color: var(--accent); }
        .cs-stk-detail { margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--border-subtle); }
        .cs-stk-quote { font-family: 'Instrument Serif', serif; font-style: italic; font-size: 14px; color: var(--text-primary); line-height: 1.6; margin-bottom: 12px; }
        .cs-stk-row { font-family: 'DM Sans', sans-serif; font-size: 12px; color: var(--text-secondary); line-height: 1.55; margin-bottom: 6px; }
        .cs-stk-label { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.08em; color: var(--text-tertiary); margin-bottom: 3px; }
        .cs-stk-blind { background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.12); border-radius: 8px; padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: 12px; color: #f87171; line-height: 1.55; margin-top: 8px; }

        /* Framework accordion */
        .cs-fw-item { background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 12px; overflow: hidden; margin-bottom: 8px; transition: border-color 200ms; }
        .cs-fw-item:hover, .cs-fw-item.active { border-color: rgba(168,85,247,0.3); }
        .cs-fw-header { display: flex; align-items: center; gap: 14px; padding: 14px 18px; cursor: pointer; }
        .cs-fw-num { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.1em; color: var(--accent); flex-shrink: 0; }
        .cs-fw-title { font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; color: var(--text-primary); flex: 1; }
        .cs-fw-body { padding: 0 18px 16px 46px; font-family: 'DM Sans', sans-serif; font-size: 13px; color: var(--text-secondary); line-height: 1.7; }

        /* Submit checklist */
        .cs-submit-item { display: flex; align-items: flex-start; gap: 12px; padding: 14px 18px; background: var(--bg-elevated); border: 1px solid var(--border-subtle); border-radius: 10px; margin-bottom: 8px; font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--text-secondary); line-height: 1.55; }
        .cs-submit-item::before { content: '□'; color: var(--accent); font-size: 16px; flex-shrink: 0; margin-top: 1px; }

        /* Animations */
        @keyframes cs-pulse { 0%,100%{opacity:1}50%{opacity:0.4} }
        @keyframes cs-dot { 0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)} }
        @keyframes cs-shake { 0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)} }

        @media (max-width: 768px) {
          .cs-dash-grid { grid-template-columns: 1fr; }
          .cs-stakeholder-grid { grid-template-columns: 1fr 1fr; }
          section[style] { padding: 56px 20px; }
          .cs-topbar { padding: 0 20px; }
        }
        @media (max-width: 480px) {
          .cs-stakeholder-grid { grid-template-columns: 1fr; }
        }
      `}</style>

      <div className="cs-page">

        {/* Topbar */}
        <div className="cs-topbar">
          <span className="cs-logo" onClick={() => navigate('/')}>onestop<span>careers</span></span>
          <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.1em', color: 'var(--text-tertiary)', background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 100, padding: '5px 14px' }}>🔒 COHORT MEMBERS ONLY</span>
        </div>

        {/* Private banner */}
        <div style={{ background: 'rgba(168,85,247,0.07)', borderBottom: '1px solid rgba(168,85,247,0.15)', padding: '13px 32px' }}>
          <div style={{ maxWidth: 900, margin: '0 auto', display: 'flex', alignItems: 'center', justifyContent: 'space-between', flexWrap: 'wrap', gap: 10 }}>
            <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', margin: 0 }}>
              <strong style={{ color: 'var(--text-primary)' }}>Saturday AI Problem Solving Lab</strong> — PlanMyTrip Case Study · Private · Do not share this URL
            </p>
            <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 11, color: 'var(--accent)', letterSpacing: '0.08em' }}>THE GROWTH TRAP</span>
          </div>
        </div>

        {/* ═══════════════════════════════════════ */}
        {/* PHASE 0 — PRE-READ */}
        {/* ═══════════════════════════════════════ */}
        <section style={sec()}>
          <div style={inner}>

            {/* Journey map */}
            <div style={{ marginBottom: 56 }}>
              <Label text="YOUR LEARNING JOURNEY" />
              <div className="cs-journey">
                {[
                  { label: 'Pre-Read', sub: 'Business context', status: 'open' },
                  { label: 'Phase 0', sub: 'Problem statement', status: 'open' },
                  { label: 'Phase 1', sub: 'Saturday with Ketan', status: 'open' },
                  { label: 'Phase 2', sub: 'Your analysis + AI', status: phase2Unlocked ? 'open' : 'locked' },
                  { label: 'Phase 3', sub: 'Submit + debrief', status: phase2Unlocked ? 'open' : 'locked' },
                ].map((step, i, arr) => (
                  <div key={i} style={{ display: 'flex', alignItems: 'center', flex: i < arr.length - 1 ? 1 : 0 }}>
                    <div className="cs-journey-step">
                      <div className={`cs-journey-dot ${step.status}`}>{step.status === 'locked' ? '🔒' : i + 1}</div>
                      <span className={`cs-journey-label ${step.status === 'locked' ? 'locked' : ''}`}>
                        <strong>{step.label}</strong><br />{step.sub}
                      </span>
                    </div>
                    {i < arr.length - 1 && <div className="cs-journey-line" />}
                  </div>
                ))}
              </div>
            </div>

            <Label text="PRE-READ · READ BEFORE SATURDAY" />
            <H2>Understanding the PlanMyTrip business</H2>
            <Body>
              <strong style={{ color: 'var(--text-primary)' }}>PlanMyTrip.com</strong> is India's second-largest online travel aggregator. It operates three primary business lines: domestic and international flight booking, hotel and holiday packages, and intercity bus ticketing (via RideConnect). The company has approximately 42% of India's OTA market.
            </Body>

            {/* Revenue model */}
            <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '24px 28px', marginBottom: 24 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 16 }}>HOW PLANMYTRIP MAKES MONEY</p>
              <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 12 }}>
                {[
                  { segment: 'Hotels & Packages', revenue: '52%', margin: '16%', note: 'Highest margin. Strategic priority.' },
                  { segment: 'Air Ticketing', revenue: '29%', margin: '5%', note: 'Price-transparent commodity. Thin margins.' },
                  { segment: 'Bus (RideConnect)', revenue: '19%', margin: '9%', note: 'Fast growing. 70% of online bus market.' },
                ].map((s, i) => (
                  <div key={i} style={{ background: 'var(--bg-base)', border: '1px solid var(--border-subtle)', borderRadius: 10, padding: '14px 16px' }}>
                    <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, fontWeight: 600, color: 'var(--text-primary)', marginBottom: 8 }}>{s.segment}</div>
                    <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 11, color: 'var(--accent)', marginBottom: 4 }}>{s.revenue} of revenue · {s.margin} margin</div>
                    <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-tertiary)', lineHeight: 1.5 }}>{s.note}</div>
                  </div>
                ))}
              </div>
            </div>

            <Callout accent>
              <strong>Why hotels matter more than flights:</strong> Hotels generate 16% adjusted margin vs 5% for flights — 3.2x more profitable per rupee. Every ₹1 shifted from air to hotel bookings generates 3.2x the profit. This context shapes how we evaluate the case: a conversion problem in flights is still a P&L problem, not just a product metric.
            </Callout>

            <Body>
              <strong style={{ color: 'var(--text-primary)' }}>The flight booking funnel:</strong> Users go through Homepage → Search (origin + dates) → Results Page → Flight Detail → Checkout → Payment → Confirmation. Each step has a drop-off rate. <strong style={{ color: 'var(--text-primary)' }}>Conversion rate = confirmed paid bookings / sessions with at least one flight search.</strong>
            </Body>

            <Body>
              <strong style={{ color: 'var(--text-primary)' }}>Competitive environment:</strong> TripEase is the market leader at 47% share. All OTAs show the same flight prices — differentiation is on UX, loyalty, and ancillary services. TripEase launched an aggressive cashback campaign on July 5. PlanMyTrip's growth team responded on July 12 by scaling app install campaigns significantly.
            </Body>

            {/* Glossary */}
            <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '24px 28px', marginBottom: 0 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 16 }}>KEY METRICS GLOSSARY</p>
              <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 10 }}>
                {[
                  { term: 'Take Rate', def: 'Revenue as % of gross booking value. Flights: ~5%, Hotels: ~16%.' },
                  { term: 'Search-to-Booking Conversion', def: 'Confirmed paid bookings / sessions with ≥1 flight search.' },
                  { term: 'Listing Click Rate', def: '% of search sessions where user clicked ≥1 flight result.' },
                  { term: 'Cost per First Paid Booking', def: 'Marketing spend / first-ever paid bookings from that channel.' },
                  { term: 'Cohort Month-1 Retention', def: '% of users who book again in the month after their first booking.' },
                  { term: 'Sample Ratio Mismatch (SRM)', def: 'When actual experiment exposure % ≠ intended %. Makes results unreliable.' },
                  { term: 'Mix Shift', def: 'Aggregate metric changes because segment composition changed — not performance.' },
                  { term: 'Net Revenue per Booking', def: '(Booking price × take rate) − discount applied per booking.' },
                ].map((g, i) => (
                  <div key={i} style={{ background: 'var(--bg-base)', borderRadius: 8, padding: '12px 14px' }}>
                    <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, fontWeight: 600, color: 'var(--text-primary)', marginBottom: 4 }}>{g.term}</div>
                    <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-tertiary)', lineHeight: 1.55 }}>{g.def}</div>
                  </div>
                ))}
              </div>
            </div>

            {/* Pre-read self check */}
            <div style={{ background: 'rgba(34,197,94,0.05)', border: '1px solid rgba(34,197,94,0.2)', borderRadius: 14, padding: '24px 28px', marginTop: 24 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: '#4ade80', marginBottom: 14 }}>PRE-READ SELF-CHECK — CAN YOU ANSWER THESE?</p>
              {[
                'Why does PMT care more about hotel bookings than flight bookings?',
                'What does "search-to-booking conversion" actually measure?',
                'What is a "take rate" and how does it differ between flights and hotels?',
                'What happened in PlanMyTrip\'s competitive environment in early July 2024?',
              ].map((q, i) => (
                <div key={i} style={{ display: 'flex', gap: 10, marginBottom: 10, fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.6 }}>
                  <span style={{ color: '#4ade80', flexShrink: 0 }}>✓</span>{q}
                </div>
              ))}
              <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-tertiary)', marginTop: 8, marginBottom: 0 }}>If you can answer all four, you're ready for Saturday. If not — re-read the business context above.</p>
            </div>
          </div>
        </section>

        {/* ═══════════════════════════════════════ */}
        {/* PHASE 0 — PROBLEM STATEMENT */}
        {/* ═══════════════════════════════════════ */}
        <section style={sec('var(--bg-surface)')}>
          <div style={inner}>
            <Label text="PHASE 0 · THE PROBLEM STATEMENT" />
            <H2>What you are being asked to solve</H2>

            {/* CEO Brief */}
            <div style={{ background: 'var(--bg-elevated)', border: '1px solid rgba(168,85,247,0.2)', borderRadius: 16, padding: '28px', marginBottom: 28, position: 'relative', overflow: 'hidden' }}>
              <div style={{ position: 'absolute', top: 0, left: 0, right: 0, height: 2, background: 'linear-gradient(90deg, var(--accent), #FF6B9D)' }} />
              <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.12em', color: 'var(--text-tertiary)', marginBottom: 16, lineHeight: 1.8 }}>
                FROM: Arjun Mehta, Group CEO, PlanMyTrip.com<br />
                TO: Analytics & Product Team<br />
                SUBJECT: Flight Conversion — Urgent Diagnosis Needed
              </div>
              <p style={{ fontFamily: 'Instrument Serif, serif', fontSize: 18, color: 'var(--text-primary)', lineHeight: 1.65, fontStyle: 'italic', marginBottom: 0 }}>
                "Over the past 8 weeks (July 1 – August 25, 2024), our domestic flight search-to-booking conversion dropped from 21.3% to 15.2% — a relative decline of 29% — despite search sessions growing 53% year over year. We are spending ₹610 per booking in discounts to partially sustain volumes that used to be self-sustaining at ₹380. Net revenue per booking has fallen from ₹342 to ₹248. If this continues for 6 more weeks, we miss Q2 contribution margin by ₹180 crore. I need the root cause and a recommendation by Saturday."
              </p>
            </div>

            <Body>
              <strong style={{ color: 'var(--text-primary)' }}>Why this is a hard problem:</strong> Traffic is up. Marketing spend is up. Yet conversion is falling and unit economics are deteriorating. This means the cause is not about volume — something about the quality of the traffic or experience changed. Multiple stakeholders have different explanations and they all disagree.
            </Body>

            {/* What strong looks like */}
            <div style={{ background: 'rgba(34,197,94,0.05)', border: '1px solid rgba(34,197,94,0.2)', borderRadius: 14, padding: '20px 24px', marginBottom: 28 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.12em', color: '#4ade80', marginBottom: 12 }}>WHAT A STRONG ANSWER LOOKS LIKE</p>
              <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.75, margin: 0 }}>
                A strong response names <strong style={{ color: 'var(--text-primary)' }}>one root cause</strong> with supporting evidence from at least two datasets. It explains why the aggregate metric declined without relying on surface-level observations. It sizes the contribution of each driver. It recommends <strong style={{ color: 'var(--text-primary)' }}>one specific action</strong> with an owner, an expected impact, and a success metric. It does not say "investigate further."
              </p>
            </div>

            {/* Initial Dashboard */}
            <Label text="INITIAL DASHBOARD — WHAT YOU SEE FIRST" />
            <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.7, marginBottom: 20 }}>
              These are the metrics the business is looking at. Some are reliable. Some are misleading. Click any card to understand what it really means.
            </p>
            <div className="cs-dash-grid">
              {DASHBOARD_METRICS.map((m, i) => (
                <div key={i} className={`cs-dash-card${!m.reliable ? ' misleading' : ''}${activeDashMetric === i ? ' active' : ''}`} onClick={() => setActiveDashMetric(activeDashMetric === i ? null : i)}>
                  {!m.reliable && <div className="cs-mislead-badge">⚠ POTENTIALLY MISLEADING</div>}
                  {m.primary && <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 9, letterSpacing: '0.1em', color: 'var(--accent)', marginBottom: 4 }}>PRIMARY METRIC</div>}
                  <div className="cs-dash-metric-name">{m.name}</div>
                  <div className="cs-dash-row">
                    <span className="cs-dash-current">{m.current}</span>
                    <span className="cs-dash-baseline">was {m.baseline}</span>
                    <span className="cs-dash-change" style={{ color: m.change.startsWith('-') ? '#f87171' : '#4ade80' }}>{m.change}</span>
                  </div>
                  {activeDashMetric === i && (
                    <div className="cs-dash-note">
                      {m.misleading ? <span style={{ color: '#fbbf24' }}>{m.misleading}</span> : m.note}
                    </div>
                  )}
                </div>
              ))}
            </div>

            {/* Stakeholders */}
            <Label text="STAKEHOLDER PERSPECTIVES — THEY ALL DISAGREE" />
            <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.7, marginBottom: 20 }}>
              Six leaders. Six different explanations. All of them have real data behind their view. All of them have a blind spot. Click each one to understand their perspective — and what they're missing.
            </p>
            <div className="cs-stakeholder-grid">
              {STAKEHOLDERS.map((s, i) => (
                <div key={i} className={`cs-stk-card${activeStakeholder === i ? ' active' : ''}`} onClick={() => setActiveStakeholder(activeStakeholder === i ? null : i)}>
                  <div className="cs-stk-avatar" style={{ background: s.color }}>{s.initials}</div>
                  <div className="cs-stk-name">{s.name}</div>
                  <div className="cs-stk-title">{s.title}</div>
                  {activeStakeholder === i && (
                    <div className="cs-stk-detail">
                      <div className="cs-stk-quote">"{s.quote}"</div>
                      <div className="cs-stk-label">WATCHES</div>
                      <div className="cs-stk-row">{s.watches}</div>
                      <div className="cs-stk-label">WANTS</div>
                      <div className="cs-stk-row">{s.wants}</div>
                      <div className="cs-stk-blind">⚠ Blind spot: {s.blind_spot}</div>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>        {/* ═══════════════════════════════════════ */}
        {/* PHASE 1 — INVESTIGATION KICKOFF */}
        {/* ═══════════════════════════════════════ */}
        <section style={sec()}>
          <div style={inner}>
            <div className="cs-phase-hdr">
              <span className="cs-phase-num">01</span>
              <div>
                <Label text="PHASE 1 · SATURDAY SESSION · 90 MINUTES" />
                <H2>Investigation Kickoff with Ketan</H2>
              </div>
            </div>

            <Body>
              Phase 1 is <strong style={{ color: 'var(--text-primary)' }}>not a course</strong>. It is investigation onboarding — the session where Ketan walks through how to approach this problem before you begin independent work in Phase 2.
            </Body>

            {/* ── Block 1: Before You Begin ── */}
            <div style={{ background: 'rgba(168,85,247,0.04)', border: '1px solid rgba(168,85,247,0.15)', borderRadius: 14, padding: '24px 28px', marginBottom: 28 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 14 }}>BEFORE YOU BEGIN — SET EXPECTATIONS</p>
              <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16, marginBottom: 20 }}>
                {[
                  { icon: '✓', text: 'No single correct answer exists. Ambiguity is intentional.' },
                  { icon: '✓', text: 'Structured thinking matters more than speed.' },
                  { icon: '✓', text: 'AI is encouraged. You will learn how to use it effectively.' },
                  { icon: '✓', text: 'You investigate independently after this session.' },
                ].map((item, i) => (
                  <div key={i} style={{ display: 'flex', gap: 10, alignItems: 'flex-start' }}>
                    <span style={{ color: '#4ade80', fontSize: 16, flexShrink: 0 }}>{item.icon}</span>
                    <span style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.6 }}>{item.text}</span>
                  </div>
                ))}
              </div>
              <div style={{ background: 'var(--bg-base)', border: '1px solid var(--border-subtle)', borderRadius: 10, padding: '16px 20px' }}>
                <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.12em', color: 'var(--accent)', marginBottom: 10 }}>BY END OF PHASE 1 YOU WILL BE ABLE TO:</p>
                <ul style={{ margin: 0, paddingLeft: 20, fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.85 }}>
                  <li>Structure the problem using a metric decomposition tree</li>
                  <li>Form testable hypotheses across traffic, product, and pricing</li>
                  <li>Identify which investigation paths to prioritize</li>
                  <li>Use AI as a thinking partner (not an answer machine)</li>
                  <li>Begin Phase 2 investigation with confidence</li>
                </ul>
              </div>
            </div>

            {/* ── Block 2: Session Timeline ── */}
            <Label text="WHAT HAPPENS IN THE 90-MINUTE SESSION" />
            <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, overflow: 'hidden', marginBottom: 28 }}>
              {[
                { time: '0:00', title: 'Business grounding', desc: 'Ketan grounds the problem — why PMT cares, what conversion means here, and why this is urgent' },
                { time: '0:15', title: 'Dashboard review', desc: 'Group examines the 8 metrics together. Which do you trust? Which are misleading? Why?' },
                { time: '0:30', title: 'Framework walkthrough', desc: 'Ketan applies the 8-step framework live — you see the thinking process, not just the output' },
                { time: '0:50', title: 'Hypothesis generation', desc: 'Group generates 5+ plausible causes across traffic quality, product, pricing, payment, experiments' },
                { time: '1:10', title: 'AI demonstration', desc: 'Ketan uses AI as a thinking partner on a real hypothesis — live on screen with actual prompts' },
                { time: '1:25', title: 'Alignment & unlock', desc: 'Group aligns on 2-3 priority hypotheses to test. Ketan shares Phase 2 keyword.' },
              ].map((s, i, arr) => (
                <div key={i} style={{ display: 'flex', gap: 18, padding: '16px 24px', borderBottom: i < arr.length - 1 ? '1px solid var(--border-subtle)' : 'none', alignItems: 'flex-start' }}>
                  <div style={{ width: 48, flexShrink: 0, paddingTop: 2 }}>
                    <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 12, fontWeight: 600, color: 'var(--accent)', letterSpacing: '0.08em' }}>{s.time}</div>
                  </div>
                  <div style={{ flex: 1 }}>
                    <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, fontWeight: 600, color: 'var(--text-primary)', marginBottom: 4 }}>{s.title}</div>
                    <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.65 }}>{s.desc}</div>
                  </div>
                </div>
              ))}
            </div>

            {/* ── Block 3: Problem Decomposition ── */}
            <Label text="BREAKING THE PROBLEM DOWN — METRIC DECOMPOSITION" />
            <Body>
              Business metrics are systems, not isolated numbers. Before investigating, you must understand how the primary metric decomposes into its drivers.
            </Body>

            <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '24px 28px', marginBottom: 20 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.12em', color: 'var(--accent)', marginBottom: 18 }}>START HERE</p>
              <div style={{ fontFamily: 'Instrument Serif, serif', fontSize: 20, color: 'var(--text-primary)', marginBottom: 6, lineHeight: 1.3 }}>
                "Conversion dropped from 18.2% to 15.1%"
              </div>
              <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-tertiary)', marginBottom: 20 }}>
                This is a symptom. Your job is to find the cause.
              </div>

              {/* Decomposition tree */}
              <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
                {[
                  {
                    level: 'Overall Metric',
                    formula: 'Conversion Rate = Bookings ÷ Sessions',
                    insight: '18.2% → 15.1% (-3.1pp)',
                    color: 'rgba(168,85,247,0.08)',
                  },
                  {
                    level: 'Revenue Impact',
                    formula: 'Revenue = Traffic × Conversion × AOV',
                    insight: 'All three components can drive change',
                    color: 'rgba(168,85,247,0.06)',
                  },
                  {
                    level: 'Segment Analysis',
                    formula: 'Overall = Σ (Segment Share × Segment Rate)',
                    insight: 'Mix shifts can lower aggregate without performance declining',
                    color: 'rgba(168,85,247,0.04)',
                  },
                  {
                    level: 'Funnel Breakdown',
                    formula: 'Conversion = Search→Click × Click→Checkout × Checkout→Pay',
                    insight: 'Which stage shows the largest absolute drop?',
                    color: 'rgba(168,85,247,0.02)',
                  },
                ].map((step, i) => (
                  <div key={i} style={{ background: step.color, border: '1px solid var(--border-subtle)', borderRadius: 10, padding: '14px 18px' }}>
                    <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.1em', color: 'var(--accent)', marginBottom: 6 }}>{step.level}</div>
                    <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 13, color: 'var(--text-primary)', marginBottom: 6, fontWeight: 500 }}>{step.formula}</div>
                    <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-secondary)', lineHeight: 1.5 }}>{step.insight}</div>
                  </div>
                ))}
              </div>
            </div>

            <Callout accent>
              <strong>Core insight:</strong> A metric can decline in two ways — (1) performance worsens within segments, or (2) mix shifts toward lower-performing segments. Most people jump to (1). Experts check (2) first.
            </Callout>

            {/* ── Block 4: How to Approach ── */}
            <Label text="HOW TO APPROACH THE INVESTIGATION" />
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: 10, marginBottom: 28 }}>
              {[
                { title: 'Start Broad, Then Narrow', desc: 'Begin with aggregate metrics. Identify patterns before investigating individual segments. Avoid premature conclusions.' },
                { title: 'Validate Before Interpreting', desc: 'Check data quality, metric definitions, and calculation logic. Bad data leads to confident wrong answers.' },
                { title: 'Separate Symptoms from Causes', desc: 'Conversion dropping is a symptom. Traffic mix shift might be a cause. Always distinguish between the two.' },
                { title: 'Quantify Business Impact', desc: 'Every finding should answer: how much revenue impact? Which segments matter most? What\'s the priority?' },
              ].map((item, i) => (
                <div key={i} style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 12, padding: '16px 20px' }}>
                  <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, fontWeight: 600, color: 'var(--text-primary)', marginBottom: 6 }}>{item.title}</div>
                  <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.65 }}>{item.desc}</div>
                </div>
              ))}
            </div>

            {/* ── Block 5: Investigation Checklist ── */}
            <Label text="INITIAL INVESTIGATION CHECKLIST — PREVENT RANDOM ANALYSIS" />
            <Body>
              Before diving into datasets, run through this checklist. It prevents the most common mistake: investigating randomly without structure.
            </Body>
            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: 8, marginBottom: 28 }}>
              {[
                { item: 'Validate metric definitions', sub: 'Confirm what "conversion" actually measures in this context' },
                { item: 'Check funnel movement', sub: 'Which stage shows the largest absolute drop?' },
                { item: 'Segment key metrics', sub: 'Is the decline uniform or concentrated in specific channels/users?' },
                { item: 'Compare before vs after changes', sub: 'What changed in early July? New experiments? Campaigns? Pricing?' },
                { item: 'Identify experiments/releases', sub: 'Were any A/B tests running? Did any launch on July 12?' },
                { item: 'Quantify impact', sub: 'Size each driver\'s contribution to the aggregate decline' },
              ].map((c, i) => (
                <div key={i} style={{ display: 'flex', gap: 10, background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 10, padding: '12px 16px', alignItems: 'flex-start' }}>
                  <span style={{ color: 'var(--accent)', fontSize: 16, flexShrink: 0 }}>□</span>
                  <div>
                    <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, fontWeight: 600, color: 'var(--text-primary)', marginBottom: 2 }}>{c.item}</div>
                    <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-tertiary)', lineHeight: 1.5 }}>{c.sub}</div>
                  </div>
                </div>
              ))}
            </div>

            {/* ── Block 6: Using AI ── */}
            <Label text="USING AI DURING INVESTIGATION — FRAME IT CORRECTLY" />
            <Body>
              AI is a thinking partner, not an answer machine. Strong analysts use AI to accelerate investigation while maintaining intellectual rigor.
            </Body>

            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12, marginBottom: 28 }}>
              {/* Good usage */}
              <div style={{ background: 'rgba(34,197,94,0.04)', border: '1px solid rgba(34,197,94,0.18)', borderRadius: 12, padding: '18px 22px' }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 12 }}>
                  <span style={{ fontSize: 18 }}>✓</span>
                  <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.12em', color: '#4ade80' }}>GOOD AI USAGE</span>
                </div>
                <ul style={{ margin: 0, paddingLeft: 18, fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.75 }}>
                  <li>Generate hypotheses to test</li>
                  <li>Write SQL queries faster</li>
                  <li>Challenge your reasoning</li>
                  <li>Explain business concepts</li>
                  <li>Suggest which dataset to check</li>
                </ul>
              </div>

              {/* Bad usage */}
              <div style={{ background: 'rgba(239,68,68,0.04)', border: '1px solid rgba(239,68,68,0.18)', borderRadius: 12, padding: '18px 22px' }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 12 }}>
                  <span style={{ fontSize: 18 }}>✗</span>
                  <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.12em', color: '#f87171' }}>BAD AI USAGE</span>
                </div>
                <ul style={{ margin: 0, paddingLeft: 18, fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.75 }}>
                  <li>Ask "what\'s the root cause"</li>
                  <li>Accept conclusions without validation</li>
                  <li>Let AI write your full report</li>
                  <li>Use it to avoid thinking</li>
                  <li>Trust outputs blindly</li>
                </ul>
              </div>
            </div>

            <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 12, padding: '16px 20px', marginBottom: 28 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.12em', color: 'var(--accent)', marginBottom: 10 }}>EXAMPLE PROMPTS KETAN WILL DEMONSTRATE</p>
              <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
                {[
                  '"My hypothesis is that paid_social traffic quality declined. What would I expect to see in the funnel data if this were true?"',
                  '"Help me write SQL to compare conversion rates by channel between baseline and problem period."',
                  '"I found that conversion dropped uniformly across all segments. Challenge this — what could I be missing?"',
                  '"Explain what a \'mix shift\' is and how to calculate its contribution to an aggregate metric change."',
                ].map((prompt, i) => (
                  <div key={i} style={{ fontFamily: 'DM Mono, monospace', fontSize: 12, color: 'var(--text-secondary)', padding: '10px 14px', background: 'var(--bg-base)', borderRadius: 8, lineHeight: 1.6 }}>
                    {prompt}
                  </div>
                ))}
              </div>
            </div>

            {/* ── Block 7: Expected Submission ── */}
            <Label text="WHAT YOU WILL SUBMIT IN PHASE 3" />
            <Body>
              After completing Phase 2 investigation, you will submit a structured report. Here's what Ketan expects to see.
            </Body>

            <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '24px 28px', marginBottom: 28 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 16 }}>EXPECTED DELIVERABLE COMPONENTS</p>
              <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
                {[
                  { component: 'Root cause narrative', desc: 'One clear sentence stating what caused the conversion drop' },
                  { component: 'Supporting evidence', desc: 'Data from at least 2 datasets that validates your root cause' },
                  { component: 'Segmentation analysis', desc: 'Which user segments, channels, or cohorts are most affected?' },
                  { component: 'Quantified impact', desc: 'How much of the 6.1pp decline does your root cause explain?' },
                  { component: 'Recommendation', desc: 'Specific action, owner, expected impact, and success metric' },
                  { component: 'Prioritization logic', desc: 'Why this recommendation over other possible interventions?' },
                ].map((item, i) => (
                  <div key={i} style={{ display: 'flex', gap: 14, padding: '12px 16px', background: 'var(--bg-base)', borderRadius: 10, alignItems: 'flex-start' }}>
                    <span style={{ width: 24, height: 24, borderRadius: '50%', background: 'rgba(168,85,247,0.1)', border: '1px solid rgba(168,85,247,0.2)', display: 'flex', alignItems: 'center', justifyContent: 'center', fontFamily: 'DM Mono, monospace', fontSize: 11, color: 'var(--accent)', flexShrink: 0 }}>{i + 1}</span>
                    <div style={{ flex: 1 }}>
                      <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, fontWeight: 600, color: 'var(--text-primary)', marginBottom: 3 }}>{item.component}</div>
                      <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-secondary)', lineHeight: 1.55 }}>{item.desc}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            {/* ── Block 8: Transition to Phase 2 ── */}
            <div style={{ background: 'linear-gradient(135deg, rgba(168,85,247,0.08), rgba(255,107,157,0.08))', border: '1px solid rgba(168,85,247,0.2)', borderRadius: 14, padding: '28px 32px', marginBottom: 0 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 12 }}>READY FOR INDEPENDENT INVESTIGATION</p>
              <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 15, color: 'var(--text-primary)', lineHeight: 1.75, marginBottom: 16 }}>
                After Saturday's session, you will have:
              </p>
              <ul style={{ margin: '0 0 20px 0', paddingLeft: 20, fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.85 }}>
                <li>A structured approach to the problem (8-step framework)</li>
                <li>2-3 prioritized hypotheses to investigate</li>
                <li>An understanding of how to use AI as a thinking partner</li>
                <li>The Phase 2 unlock keyword to access the full dataset explorer</li>
              </ul>
              <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.75, marginBottom: 0 }}>
                <strong style={{ color: 'var(--text-primary)' }}>Phase 2 is where you independently investigate</strong> using the 5 datasets, SQL queries, and AI Analysis Partner. You will work through the data, test your hypotheses, and build your case before submitting to Ketan for evaluation.
              </p>
            </div>

            {/* ── What to Bring ── */}
            <Callout>
              <strong>What to bring to Saturday:</strong> Read the Pre-Read and Phase 0 Problem Statement above. Look at the initial dashboard. Come with at least one hypothesis — even if you're not sure it's right. The session works best when everyone has a view to defend and challenge.
            </Callout>

          </div>
        </section>

        {/* ═══════════════════════════════════════ */}
        {/* PHASE 2 — ANALYSIS (LOCKED) */}
        {/* ═══════════════════════════════════════ */}
        <section style={sec('var(--bg-surface)')}>
          <div style={inner}>
            <div className="cs-phase-hdr">
              <span className="cs-phase-num">02</span>
              <div>
                <Label text="PHASE 2 · INDEPENDENT WORK · UNLOCKS AFTER SESSION 1" />
                <H2>Your analysis</H2>
              </div>
            </div>

            {!phase2Unlocked ? (
              <>
                <Body>Phase 2 contains the full dataset explorer, the 6-step investigation framework, and the AI Analysis Partner. Ketan will share the unlock keyword at the end of Saturday's session.</Body>
                <Body>While you wait — re-read the problem statement and stakeholder perspectives above. Come to Saturday with hypotheses.</Body>

                {/* Preview of what's inside */}
                <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '24px', marginBottom: 28, opacity: 0.7 }}>
                  <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--text-tertiary)', marginBottom: 16 }}>WHAT IS INSIDE PHASE 2 (locked)</p>
                  {['5 real datasets to investigate (funnel by channel, cohort quality, competitor pricing, experiments, session mix)', 'A 6-step investigation framework to guide your analysis', 'The AI Analysis Partner — asks questions, challenges hypotheses, gives hints', 'SQL query examples for each dataset'].map((item, i) => (
                    <div key={i} style={{ display: 'flex', gap: 10, marginBottom: 10, fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-tertiary)', lineHeight: 1.55 }}>
                      <span>🔒</span>{item}
                    </div>
                  ))}
                </div>
                <PhaseLock onUnlock={() => setPhase2Unlocked(true)} />
              </>
            ) : (
                            <>
                {/* ── Unlock banner ── */}
                <div style={{ background: 'rgba(34,197,94,0.06)', border: '1px solid rgba(34,197,94,0.2)', borderRadius: 12, padding: '14px 20px', marginBottom: 28, display: 'flex', alignItems: 'center', gap: 10 }}>
                  <span style={{ color: '#4ade80', fontSize: 18 }}>✓</span>
                  <span style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: '#4ade80' }}>Phase 2 unlocked. Work through the datasets below, then use the AI to pressure-test your thinking.</span>
                </div>

                {/* ── Reflection checkpoint modal ── */}
                {showReflection && (
                  <ReflectionCheckpoint onComplete={(ans) => {
                    setReflectionAnswer(ans)
                    setShowReflection(false)
                    setReflectionDone(true)
                  }} />
                )}

                {/* ── Reflection saved indicator ── */}
                {reflectionDone && (
                  <div style={{ background: 'rgba(168,85,247,0.04)', border: '1px solid rgba(168,85,247,0.15)', borderRadius: 10, padding: '12px 18px', marginBottom: 20, display: 'flex', gap: 10, alignItems: 'flex-start' }}>
                    <span style={{ color: 'var(--accent)', flexShrink: 0 }}>✎</span>
                    <div>
                      <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.1em', color: 'var(--accent)' }}>YOUR HYPOTHESIS (saved)</span>
                      <p style={{ fontFamily: 'Instrument Serif, serif', fontStyle: 'italic', fontSize: 14, color: 'var(--text-primary)', lineHeight: 1.65, marginTop: 4, marginBottom: 0 }}>"{reflectionAnswer}"</p>
                    </div>
                  </div>
                )}

                {/* ── Investigation framework ── */}
                <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '24px', marginBottom: 28 }}>
                  <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 16 }}>YOUR 6-STEP INVESTIGATION FRAMEWORK</p>
                  {[
                    { n: '01', t: 'Start with the funnel', d: 'Open Dataset 1. Which funnel stage shows the largest absolute drop? Do not proceed until you have answered this with a number.' },
                    { n: '02', t: 'Segment the drop', d: 'Is the conversion decline uniform across all channels and user types — or concentrated in a specific segment? Use Datasets 1 and 5.' },
                    { n: '03', t: 'Form your root cause hypothesis', d: 'Based on what you found in Step 2, what single explanation best fits ALL the data patterns? State it in one sentence.' },
                    { n: '04', t: 'Find corroborating evidence', d: 'Does Dataset 2 (cohort quality) support your hypothesis? Does Dataset 3 (competitor pricing) add context? Does Dataset 4 (experiments) contain a partial explanation?' },
                    { n: '05', t: 'Check data quality', d: 'Before finalising: Are there duplicates in the booking data? Does EXP_SORT_ALGO_V3 have a sample ratio mismatch? Can you trust all your numbers?' },
                    { n: '06', t: 'Size your contribution estimates', d: 'How much of the 6.1pp aggregate conversion drop does your root cause explain? Use the mix shift formula: Δshare × conversion_gap. Quantify before recommending.' },
                  ].map((step, i) => (
                    <div key={i} style={{ display: 'flex', gap: 16, padding: '14px 0', borderBottom: i < 5 ? '1px solid var(--border-subtle)' : 'none' }}>
                      <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 12, color: 'var(--accent)', flexShrink: 0, paddingTop: 2 }}>{step.n}</span>
                      <div>
                        <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, fontWeight: 600, color: 'var(--text-primary)', marginBottom: 5 }}>{step.t}</div>
                        <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.65 }}>{step.d}</div>
                      </div>
                    </div>
                  ))}
                </div>

                {/* ── Datasets ── */}
                <Label text="THE DATA — 5 DATASETS TO INVESTIGATE" />
                <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.7, marginBottom: 20 }}>
                  Work through these in order. Each answers a different question. Use the hints only after you've genuinely tried — there are 3 escalating hints per dataset.
                </p>
                {DATASETS.map((ds, idx) => (
                  <DatasetTable
                    key={ds.id}
                    ds={ds}
                    onFirstOpen={(id) => {
                      const now = Date.now()
                      setDatasetsOpened(prev => {
                        const next = new Set(prev)
                        next.add(id)
                        sessionStorage.setItem('phase2_datasets_opened', JSON.stringify([...next]))
                        return next
                      })
                      // Trigger reflection checkpoint after Dataset 3 (competitor)
                      if (id === 'competitor' && !reflectionDone && !showReflection) {
                        setTimeout(() => setShowReflection(true), 800)
                      }
                    }}
                  />
                ))}

                {/* ── Dataset progress indicator ── */}
                <div style={{ display: 'flex', alignItems: 'center', gap: 10, padding: '14px 18px', background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 10, marginBottom: 28, marginTop: 8 }}>
                  <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 11, color: 'var(--text-tertiary)', letterSpacing: '0.06em' }}>DATASETS OPENED:</span>
                  {DATASETS.map(ds => (
                    <div key={ds.id} style={{ display: 'flex', alignItems: 'center', gap: 4 }}>
                      <div style={{ width: 8, height: 8, borderRadius: '50%', background: datasetsOpened.has(ds.id) ? '#4ade80' : 'var(--border-subtle)', transition: 'background 300ms' }} />
                      <span style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, color: datasetsOpened.has(ds.id) ? '#4ade80' : 'var(--text-tertiary)' }}>
                        {ds.id === 'funnel' ? 'D1' : ds.id === 'cohort' ? 'D2' : ds.id === 'competitor' ? 'D3' : ds.id === 'experiments' ? 'D4' : 'D5'}
                      </span>
                    </div>
                  ))}
                  <span style={{ marginLeft: 'auto', fontFamily: 'DM Mono, monospace', fontSize: 10, color: datasetsOpened.size >= 4 ? '#4ade80' : 'var(--text-tertiary)' }}>
                    {datasetsOpened.size}/5 opened {datasetsOpened.size >= 4 ? '✓' : ''}
                  </span>
                </div>

                {/* ── SQL reference ── */}
                <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '24px', marginBottom: 28 }}>
                  <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 16 }}>KEY SQL QUERY — Start with this</p>
                  <pre style={{ fontFamily: 'DM Mono, monospace', fontSize: 12, color: 'var(--text-secondary)', lineHeight: 1.8, overflowX: 'auto', margin: 0, whiteSpace: 'pre-wrap' }}>{`SELECT
  DATE_TRUNC('week', s.session_start_ts) as week,
  COALESCE(s.channel_attribution, 'unknown') as channel,
  COUNT(DISTINCT s.session_id) as sessions,
  COUNT(DISTINCT CASE WHEN b.booking_status = 'confirmed'
        THEN b.booking_id END) as confirmed_bookings,
  ROUND(100.0 * COUNT(DISTINCT CASE WHEN b.booking_status = 'confirmed'
        THEN b.booking_id END)
    / NULLIF(COUNT(DISTINCT s.session_id), 0), 2) as conversion_pct
FROM sessions s
LEFT JOIN search_events se ON s.session_id = se.session_id
LEFT JOIN bookings b ON se.search_id = b.search_id
WHERE s.session_start_ts >= '2024-04-01'
GROUP BY 1, 2
ORDER BY 1, sessions DESC;`}</pre>
                  <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 12, color: 'var(--text-tertiary)', marginTop: 12, marginBottom: 0, lineHeight: 1.6 }}>
                    ⚠ Join warning: sessions → search_events is one-to-many. Do not join sessions directly to bookings.
                  </p>
                </div>

                {/* ── AI Assistant ── */}
                <Label text="AI ANALYSIS PARTNER" />
                <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.7, marginBottom: 20 }}>
                  Use the AI to challenge your hypotheses and get unstuck. <strong style={{ color: 'var(--text-primary)' }}>It will not give you the answer.</strong> It will help you find it yourself.
                </p>
                <div style={{ background: 'rgba(168,85,247,0.04)', border: '1px solid rgba(168,85,247,0.15)', borderRadius: 10, padding: '14px 18px', marginBottom: 20 }}>
                  <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.1em', color: 'var(--accent)', marginBottom: 10 }}>EFFECTIVE PROMPTS</p>
                  {[
                    '"My hypothesis is that [X]. What would I expect to see in Dataset [Y] if this were true?"',
                    '"I found that paid_social converts at 2.5%. What does this mean for the aggregate metric?"',
                    '"Help me write SQL to compute session share by channel over time."',
                    '"I’m trying to size the contribution of mix shift. Walk me through the calculation."',
                  ].map((p, i) => (
                    <div key={i} style={{ fontFamily: 'DM Mono, monospace', fontSize: 12, color: 'var(--text-secondary)', marginBottom: 6, lineHeight: 1.6 }}>{p}</div>
                  ))}
                </div>
                <AIChat phase={2} />

                {/* ── Mark Phase 2 Complete ── */}
                {(() => {
                  const datasetsReady = datasetsOpened.size >= 4
                  const reflectionReady = reflectionDone
                  const canComplete = datasetsReady && reflectionReady
                  const missing = []
                  if (!datasetsReady) missing.push(`open ${4 - datasetsOpened.size} more dataset${4 - datasetsOpened.size > 1 ? 's' : ''}`)
                  if (!reflectionReady) missing.push('complete the reflection checkpoint (auto-triggers after Dataset 3)')
                  return (
                    <div style={{ marginTop: 36, background: canComplete ? 'rgba(34,197,94,0.05)' : 'var(--bg-elevated)', border: `1px solid ${canComplete ? 'rgba(34,197,94,0.25)' : 'var(--border-subtle)'}`, borderRadius: 16, padding: '28px 32px', textAlign: 'center', transition: 'all 300ms' }}>
                      <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: canComplete ? '#4ade80' : 'var(--text-tertiary)', marginBottom: 12 }}>
                        {canComplete ? 'INVESTIGATION COMPLETE — READY FOR PHASE 3' : 'COMPLETE TO UNLOCK PHASE 3'}
                      </p>
                      {!canComplete && (
                        <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-tertiary)', marginBottom: 20, lineHeight: 1.65 }}>
                          Still needed: {missing.join(' · ')}
                        </p>
                      )}
                      {canComplete && (
                        <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.7, marginBottom: 24 }}>
                          You've worked through the data and formed a hypothesis. Phase 3 is where you turn your findings into a structured recommendation Ketan can evaluate on Saturday.
                        </p>
                      )}
                      <button
                        disabled={!canComplete}
                        onClick={() => {
                          sessionStorage.setItem('phase2_complete', '1')
                          setPhase2Complete(true)
                          setTimeout(() => {
                            document.getElementById('phase3-section')?.scrollIntoView({ behavior: 'smooth' })
                          }, 200)
                        }}
                        style={{ background: canComplete ? 'var(--accent)' : 'var(--bg-base)', border: `1px solid ${canComplete ? 'transparent' : 'var(--border-subtle)'}`, borderRadius: 100, padding: '14px 36px', color: canComplete ? '#fff' : 'var(--text-tertiary)', fontFamily: 'DM Sans, sans-serif', fontSize: 15, fontWeight: 600, cursor: canComplete ? 'pointer' : 'not-allowed', transition: 'all 200ms' }}
                      >
                        {canComplete ? 'Mark Phase 2 Complete → Enter Phase 3' : `Complete requirements above`}
                      </button>
                    </div>
                  )
                })()}
              </>
            )}
          </div>
        </section>

        {/* ═══════════════════════════════════════ */}
        {/* PHASE 3 — SUBMISSION */}
        {/* ═══════════════════════════════════════ */}
        <section style={sec()}>
          <div style={inner}>
            <div className="cs-phase-hdr">
              <span className="cs-phase-num">03</span>
              <div>
                <Label text="PHASE 3 · BEFORE NEXT SATURDAY · UNLOCKS WITH PHASE 2" />
                <H2>Submit your analysis</H2>
              </div>
            </div>

            {!phase2Unlocked ? (
              <Body>Phase 3 unlocks together with Phase 2 after Session 1. Come back after Ketan shares the keyword on Saturday.</Body>
            ) : (
              <>
                <Body>
                  Phase 3 is about turning your analysis into a structured output Ketan can evaluate on Saturday. This is the skill that separates professionals who find insights from those who can communicate them to decision-makers.
                </Body>

                {/* SCQA */}
                <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '24px', marginBottom: 28 }}>
                  <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 16 }}>THE SCQA FRAMEWORK — HOW TO STRUCTURE YOUR REPORT</p>
                  {[
                    { l: 'S — Situation', d: 'What is the context? (PMT flight conversion dropped 29% despite sessions growing 53%)' },
                    { l: 'C — Complication', d: 'Why is it a problem? (Net revenue per booking fell from ₹342 to ₹248. Discount burn accelerating. Q2 margin at risk.)' },
                    { l: 'Q — Question', d: 'What precise question are you answering? (What caused the conversion drop and what should leadership do about it?)' },
                    { l: 'A — Answer', d: 'Your recommendation, stated first. Evidence second. Not "we need to investigate further" — a specific action with expected impact.' },
                  ].map((s, i) => (
                    <div key={i} style={{ background: 'var(--bg-base)', border: '1px solid var(--border-subtle)', borderRadius: 10, padding: '14px 18px', marginBottom: 8 }}>
                      <div style={{ fontFamily: 'DM Mono, monospace', fontSize: 11, letterSpacing: '0.1em', color: 'var(--accent)', marginBottom: 6 }}>{s.l}</div>
                      <div style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.65 }}>{s.d}</div>
                    </div>
                  ))}
                </div>

                {/* Submission checklist */}
                <Label text="SUBMISSION CHECKLIST — MUST INCLUDE ALL OF THESE" />
                {[
                  'Your root cause stated in one clear sentence — not a list of possibilities',
                  'The funnel stage where conversion dropped most — with the specific number',
                  'Evidence from at least 2 datasets supporting your root cause',
                  'An explanation of why the aggregate metric declined (mix shift, performance decline, or both)',
                  'At least one data quality issue you identified and how you handled it',
                  'A specific recommendation with an owner, expected impact, and success metric',
                  'One risk or assumption in your recommendation that you acknowledge',
                ].map((item, i) => (
                  <div key={i} className="cs-submit-item">{item}</div>
                ))}

                {/* AI Report Coach */}
                <Label text="AI REPORT COACH" />
                <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.7, marginBottom: 20 }}>
                  Paste your draft recommendation here. The AI will review your SCQA structure, challenge vague recommendations, and tell you what's strong and what needs work.
                </p>
                <AIChat phase={3} />

                {/* Submission */}
                <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '28px', marginTop: 28, textAlign: 'center' }}>
                  <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 12 }}>HOW TO SUBMIT</p>
                  <p style={{ fontFamily: 'DM Sans, sans-serif', fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.75, marginBottom: 24 }}>
                    Send your report (PDF or Google Doc link) via WhatsApp before <strong style={{ color: 'var(--text-primary)' }}>Friday 6pm</strong>. Ketan will review all submissions before Saturday's evaluation session.
                  </p>
                  <a
                    href="https://wa.me/919XXXXXXXXX?text=Hi%20Ketan%2C%20here%20is%20my%20PlanMyTrip%20case%20study%20submission%3A%20"
                    target="_blank"
                    rel="noopener noreferrer"
                    style={{ display: 'inline-flex', alignItems: 'center', gap: 10, background: '#25D366', border: 'none', borderRadius: 100, padding: '14px 32px', fontFamily: 'DM Sans, sans-serif', fontSize: 15, fontWeight: 600, color: '#fff', textDecoration: 'none', cursor: 'pointer' }}
                  >
                    📱 Submit via WhatsApp →
                  </a>
                  <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 11, color: 'var(--text-tertiary)', marginTop: 14, letterSpacing: '0.06em' }}>
                    DEADLINE: FRIDAY 6PM · KETAN CONFIRMS RECEIPT VIA WHATSAPP GROUP
                  </p>
                </div>
              </>
            )}
          </div>
        </section>

        {/* ═══════════════════════════════════════ */}
        {/* SESSION 2 — DEBRIEF */}
        {/* ═══════════════════════════════════════ */}
        <section style={sec('var(--bg-surface)')}>
          <div style={inner}>
            <div className="cs-phase-hdr">
              <span className="cs-phase-num">04</span>
              <div>
                <Label text="NEXT SATURDAY · 2 HOURS · LIVE WITH KETAN" />
                <H2>Evaluation and debrief</H2>
              </div>
            </div>
            <Body>
              In Saturday's evaluation session, Ketan will review each person's submission live. He will ask you to defend your root cause, challenge your evidence, and push on your recommendation. Then he will walk through what the data actually shows — and the gap between what you found and what a seasoned analyst would have found is where you grow the most.
            </Body>
            <div style={{ background: 'var(--bg-elevated)', border: '1px solid var(--border-subtle)', borderRadius: 14, padding: '24px', marginBottom: 0 }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.14em', color: 'var(--accent)', marginBottom: 16 }}>WHAT KETAN WILL ASK YOU</p>
              {[
                '"State your root cause in one sentence."',
                '"What is the single strongest piece of evidence for it?"',
                '"What evidence, if any, contradicts it — and how do you handle that?"',
                '"Your recommendation — what is the specific action, expected impact, and success metric?"',
                '"Where are you most likely to be wrong?"',
              ].map((q, i) => (
                <div key={i} style={{ fontFamily: 'Instrument Serif, serif', fontStyle: 'italic', fontSize: 15, color: 'var(--text-primary)', padding: '10px 0', borderBottom: i < 4 ? '1px solid var(--border-subtle)' : 'none', lineHeight: 1.5 }}>
                  {q}
                </div>
              ))}
            </div>
            <div style={{ marginTop: 24, background: 'rgba(168,85,247,0.05)', border: '1px solid rgba(168,85,247,0.15)', borderRadius: 14, padding: '20px 24px' }}>
              <p style={{ fontFamily: 'DM Mono, monospace', fontSize: 10, letterSpacing: '0.12em', color: 'var(--accent)', marginBottom: 10 }}>WHAT YOU WALK AWAY WITH</p>
              {[
                'The actual root cause and how to find it using the 8-step framework',
                'A clear understanding of which hypotheses were wrong and why — and how experts rule them out',
                'The 8-step problem solving framework applied to a real case you worked through',
                'Ketan\'s personal AI prompt library and full case debrief notes',
              ].map((item, i) => (
                <div key={i} style={{ display: 'flex', gap: 10, marginBottom: 10, fontFamily: 'DM Sans, sans-serif', fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.6 }}>
                  <span style={{ color: '#4ade80' }}>✓</span>{item}
                </div>
              ))}
            </div>
          </div>
        </section>

      </div>
    </>
  )
}

  "groundTruth": {
    "rootCause": "Dynamic pricing algorithm bug introduced in Week 16 causes checkout price to be 22-35% higher than search price, triggering abandonment.",
    "affectedMetrics": ["revenue_per_booking", "checkout_conversion", "booking_completion_rate"],
    "anomalyStartWeek": 16,
    "expectedFindings": [
      "checkout_drop_off_increased_week16",
      "price_at_checkout_higher_than_search",
      "supplier_success_rate_stable",
      "affected_segments_domestic_hotels"
    ]
  },

